From 111723abcf99ab5eb923673d2704cb522cb1c87f Mon Sep 17 00:00:00 2001
From: just4honey <j4f@list.ru>
Date: Sun, 7 Jun 2026 18:28:41 +0300
Subject: [PATCH 10/10] feat: make propose_takes page_limit configurable via
 dream.propose_takes.page_limit

Usage: gbrain config set dream.propose_takes.page_limit 505
Default: 100 (backward compatible)
---
 src/core/cycle/propose-takes.ts | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/src/core/cycle/propose-takes.ts b/src/core/cycle/propose-takes.ts
index f361eb61..06cf0414 100644
--- a/src/core/cycle/propose-takes.ts
+++ b/src/core/cycle/propose-takes.ts
@@ -305,7 +305,8 @@ class ProposeTakesPhase extends BaseCyclePhase {
   ): Promise<{ summary: string; details: Record<string, unknown>; status?: PhaseStatus }> {
     const extractor = opts.extractor ?? defaultExtractor;
     const promptVersion = opts.promptVersion ?? PROPOSE_TAKES_PROMPT_VERSION;
-    const pageLimit = opts.pageLimit ?? 100;
+    const cfgPageLimit = await engine.getConfig('dream.propose_takes.page_limit');
+    const pageLimit = Number(cfgPageLimit) || opts.pageLimit || 100;
     const skipPagesWithFence = opts.skipPagesWithFence ?? false;
     const proposalRunId = `propose-${new Date().toISOString().slice(0, 19).replace(/[-:T]/g, '')}-${randomUUID().slice(0, 8)}`;
 
